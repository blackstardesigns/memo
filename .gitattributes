# Controls what gets published to the PUBLIC release repo.
#
# `.github/workflows/publish.yml` exports the source with `git archive HEAD`,
# which DROPS every path marked `export-ignore` below. Anything not listed here
# (src/, Cargo.toml, Cargo.lock, README.md, install.sh, install.ps1, docs/,
# config.example.toml, .github/workflows/release.yml, ...) IS published.
#
# Add `export-ignore` for anything that must stay private.

.claude                        export-ignore
.github/workflows/publish.yml  export-ignore
.gitattributes                 export-ignore
.gitignore                     export-ignore

# Convention: name any private-only file `something.private.ext` and it is
# never published (e.g. RELEASING.private.md).
*.private.*                    export-ignore
